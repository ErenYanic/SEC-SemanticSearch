# =============================================================================
# SEC-SemanticSearch — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.
# Lines starting with # are comments.  Uncomment and set values as needed.

# ---------------------------------------------------------------------------
# SEC EDGAR API Credentials
# ---------------------------------------------------------------------------
# Required for CLI usage.  For web deployments with per-session credentials
# (EDGAR_SESSION_REQUIRED=true), these may be left unset — each user provides
# their own name and email at session start.
EDGAR_IDENTITY_NAME="Your Name"
EDGAR_IDENTITY_EMAIL="your.email@example.com"

# EDGAR rate limiting is handled by edgartools internally (default 9 req/s).
# To override, set EDGAR_RATE_LIMIT_PER_SEC (edgartools env var).

# ---------------------------------------------------------------------------
# Hugging Face (Optional)
# ---------------------------------------------------------------------------
# Speeds up model downloads and increases usage limits.
# HUGGING_FACE_TOKEN="your_huggingface_token_here"

# ---------------------------------------------------------------------------
# Embedding Model Configuration (Optional)
# ---------------------------------------------------------------------------
# EMBEDDING_MODEL_NAME="google/embeddinggemma-300m"
# EMBEDDING_DEVICE="auto"               # "cuda", "cpu", or "auto"
# EMBEDDING_BATCH_SIZE=32               # Reduce for low-VRAM GPUs (e.g. 8)
# EMBEDDING_IDLE_TIMEOUT_MINUTES=0      # 0 = disabled; auto-unload after idle

# ---------------------------------------------------------------------------
# Text Chunking Configuration (Optional)
# ---------------------------------------------------------------------------
# CHUNKING_TOKEN_LIMIT=500
# CHUNKING_TOLERANCE=50

# ---------------------------------------------------------------------------
# Database Configuration (Optional)
# ---------------------------------------------------------------------------
# DB_CHROMA_PATH="./data/chroma_db"
# DB_METADATA_DB_PATH="./data/metadata.sqlite"
# DB_MAX_FILINGS=2500

# SQLCipher encryption key for SQLite metadata.  When set, pysqlcipher3 is
# used instead of sqlite3.  Unset = plain SQLite (local development).
#
# SCENARIO A (Local development on personal machine):
#   Use DB_ENCRYPTION_KEY — simple and appropriate for single-user dev environments.
DB_ENCRYPTION_KEY="your-encryption-key-here"
#
# SCENARIO B & C (Team/cloud deployments):
#   Use DB_ENCRYPTION_KEY_FILE instead. The key is read from a file mounted via
#   Docker secrets or Cloud secrets, avoiding exposure in /proc/<pid>/environ.
# DB_ENCRYPTION_KEY_FILE="/run/secrets/db_encryption_key"  # Docker/Cloud managed secret

# Task history privacy.
# DB_TASK_HISTORY_RETENTION_DAYS=0      # 0 = keep indefinitely
# DB_TASK_HISTORY_PERSIST_TICKERS=false # Store tickers in task_history?

# ---------------------------------------------------------------------------
# Search Configuration (Optional)
# ---------------------------------------------------------------------------
# SEARCH_TOP_K=5
# SEARCH_MIN_SIMILARITY=0.0

# ---------------------------------------------------------------------------
# Logging Configuration (Optional)
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_REDACT_QUERIES=false              # Hash search queries/tickers in logs

# Optional file logging (in addition to stdout).
# LOG_FILE_PATH=./logs/app.log
# LOG_FILE_MAX_BYTES=10485760           # 10 MB
# LOG_FILE_BACKUP_COUNT=3

# ---------------------------------------------------------------------------
# API Server Configuration (Optional)
# ---------------------------------------------------------------------------
# API_HOST=127.0.0.1
# API_PORT=8000
# API_CORS_ORIGINS='["http://localhost:3000"]'

# Authentication — unset = disabled (Scenario A / local development).
# API_KEY="your-secret-api-key-here"
# API_ADMIN_KEY="your-admin-key-here"   # For destructive operations

# Rate limiting (requests per minute; 0 = disabled).
# API_RATE_LIMIT_SEARCH=60
# API_RATE_LIMIT_INGEST=10
# API_RATE_LIMIT_DELETE=30
# API_RATE_LIMIT_GENERAL=120

# Per-session EDGAR credentials — when true, the frontend shows a Welcome
# screen where users enter their SEC EDGAR name and email.  Skipped when
# server-side EDGAR_IDENTITY_* vars are set.
# API_EDGAR_SESSION_REQUIRED=false

# Demo mode — enables nightly reset banner, FIFO eviction, disables
# "clear all".  See docs/DEPLOYMENT.md §4.6.
# API_DEMO_MODE=false
# API_DEMO_EVICTION_BUFFER=500

# Task queue size (maximum concurrent + pending ingest tasks).
# API_MAX_TASK_QUEUE_SIZE=5

# Abuse prevention caps (0 = unlimited/disabled).
# API_MAX_TICKERS_PER_REQUEST=0
# API_MAX_FILINGS_PER_REQUEST=0
# API_INGEST_COOLDOWN_SECONDS=0
# API_MAX_TASK_DURATION_MINUTES=0
